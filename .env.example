# =============================================================================
# USGS Publications Warehouse MCP Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is loaded automatically at server startup.
# NEVER commit the .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Authentication (required for HTTP transports: SSE, streamable-http)
# ---------------------------------------------------------------------------
# Static API key — used via X-API-Key header
USGS_MCP_API_KEY=

# Static Bearer token — used via Authorization: Bearer header
# Must start with "usgs_" prefix
USGS_MCP_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# Transport (optional — defaults shown)
# ---------------------------------------------------------------------------
# MCP_TRANSPORT=stdio
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# ---------------------------------------------------------------------------
# Security tuning (optional — defaults shown)
# ---------------------------------------------------------------------------
# USGS_MCP_RATE_LIMIT_REQUESTS_PER_MINUTE=60
# USGS_MCP_RATE_LIMIT_REQUESTS_PER_HOUR=1000
# USGS_MCP_MAX_QUERY_LENGTH=500
# USGS_MCP_MAX_PAGE_SIZE=100
# USGS_MCP_REQUEST_TIMEOUT_SECONDS=30
# USGS_MCP_ENFORCE_HTTPS=true
# USGS_MCP_VERIFY_SSL=true
# USGS_MCP_AUDIT_LOGGING_ENABLED=true

# ---------------------------------------------------------------------------
# Proxy header trust (optional; only when behind trusted reverse proxy)
# ---------------------------------------------------------------------------
# Leave disabled unless traffic comes through a trusted ingress/proxy.
# USGS_MCP_TRUST_PROXY_HEADERS=false
# Comma-separated trusted proxy IPs/CIDRs used to trust X-Forwarded-For.
# USGS_MCP_TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.0/8
