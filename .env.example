# =============================================================================
# USGS Publications Warehouse MCP Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is loaded automatically at server startup.
# =============================================================================

# ---------------------------------------------------------------------------
# Transport (optional — defaults shown)
# ---------------------------------------------------------------------------
# MCP_TRANSPORT=stdio
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
# MCP_DISABLE_DNS_REBINDING_PROTECTION=true

# ---------------------------------------------------------------------------
# Security tuning (optional — defaults shown)
# ---------------------------------------------------------------------------
# USGS_MCP_RATE_LIMIT_REQUESTS_PER_MINUTE=60
# USGS_MCP_RATE_LIMIT_REQUESTS_PER_HOUR=1000
# USGS_MCP_MAX_QUERY_LENGTH=500
# USGS_MCP_MAX_PAGE_SIZE=100
# USGS_MCP_REQUEST_TIMEOUT_SECONDS=30
# USGS_MCP_ENFORCE_HTTPS=true
# USGS_MCP_VERIFY_SSL=true
# USGS_MCP_AUDIT_LOGGING_ENABLED=true
